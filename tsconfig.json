{
	"compilerOptions": {
		"outDir": "./dist/",
		"module": "commonjs",
		"target": "es2017",
		"jsx": "react",
		"allowJs": true,
		"baseUrl": ".",
		"lib": ["ES2017", "DOM"],
		"moduleResolution": "node",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["api/**/*", "src/**/*"]
}
